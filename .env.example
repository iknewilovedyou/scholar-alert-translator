# Email / IMAP
EMAIL_ADDRESS=your_email@example.com
EMAIL_APP_PASSWORD=your_email_app_password_or_auth_code
IMAP_SERVER=imap.example.com
IMAP_LABEL=INBOX
SINCE_DAYS=7
MAX_EMAILS=10

# Translation API
# Supported values: openai, ark
TRANSLATE_PROVIDER=openai
OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Optional Ark/Volcengine-compatible settings
ARK_API_KEY=
TRANSLATE_BASE_URL=
TRANSLATE_MODEL=

# Optional output and notification settings
OUTPUT_DIR=./output
NOTIFY_WEBHOOK=
NOTIFY_COPY_TO=

# Optional PDF font overrides
PDF_MAIN_FONT=
PDF_CJK_FONT=
PDF_MONO_FONT=
PDF_MATH_FONT=
